print("Hello!")

def subtract(a,b):
    return a - b

def add(a,b):
    return a + b

def multiply(a,b):
    return a * b
  
def division(a,b):
    return a/b

operations={"add":add,"subtract":subtract,"divide":division,"multiply":multiply}

def ask_number(message):
    while True:
        try:
            return float(input(message))
        except ValueError:
            print("PLease enter a valid number")

while True:
    operation=input("Would you like to add,subtract,multiply or divide?").strip().lower()
    if operation not in operations:
            print("Please enter a valid operation")
            continue
    
    a=ask_number("What is your first number?")
    b=ask_number("What is your second number?")

    result=operations[operation](a,b)
    print("Answer:",result)
    print()
    cont=input("Would you like to continue with the calculations?").strip().lower()
    if cont in["yh","yes","yup","yeah","ok",""]:
        continue
    else:
        break


